:root {
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color: #172033;
  background: #f6f7fb;
}

* { box-sizing: border-box; }
body { margin: 0; }
button, input { font: inherit; }
button { cursor: pointer; }

.page {
  width: min(980px, calc(100% - 32px));
  margin: 0 auto;
  padding: 40px 0;
}

.hero {
  background: linear-gradient(135deg, #eef2ff, #ffffff);
  border: 1px solid #e3e8f7;
  border-radius: 24px;
  padding: 28px;
  box-shadow: 0 18px 60px rgba(40, 55, 90, 0.08);
}

.eyebrow {
  color: #4f46e5;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  font-size: 0.78rem;
  margin: 0 0 8px;
}

h1 { margin: 0; font-size: clamp(2rem, 5vw, 4rem); }
.subtitle { max-width: 720px; color: #566176; line-height: 1.7; }

.toolbar, .domains, .controls {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 18px;
}

.toolbar input {
  flex: 1 1 280px;
  border: 1px solid #d6dce8;
  border-radius: 14px;
  padding: 12px 14px;
  background: #fff;
}

button {
  border: 1px solid #d6dce8;
  background: #fff;
  color: #1f2937;
  padding: 10px 14px;
  border-radius: 14px;
  transition: 0.15s ease;
}
button:hover:not(:disabled), button.active { background: #4f46e5; color: white; border-color: #4f46e5; }
button:disabled { opacity: 0.45; cursor: not-allowed; }

.progress-wrap { margin-top: 22px; }
.progress-meta { display: flex; justify-content: space-between; color: #647084; font-size: 0.9rem; margin-bottom: 8px; }
.progress { height: 8px; background: #e6eaf2; border-radius: 999px; overflow: hidden; }
.progress div { height: 100%; background: #4f46e5; transition: width 0.25s ease; }

.flashcard {
  position: relative;
  min-height: 380px;
  margin-top: 24px;
  perspective: 1000px;
}

.card-face {
  position: absolute;
  inset: 0;
  border-radius: 28px;
  border: 1px solid #e1e6ef;
  padding: 28px;
  background: #fff;
  box-shadow: 0 24px 80px rgba(40, 55, 90, 0.12);
  backface-visibility: hidden;
  transition: transform 0.45s ease;
  overflow: auto;
}

.card-front { display: flex; flex-direction: column; justify-content: space-between; }
.card-front h2 { font-size: clamp(1.5rem, 4vw, 2.35rem); line-height: 1.25; margin: 28px 0; }
.card-front p { color: #647084; }
.card-back { transform: rotateY(180deg); line-height: 1.7; }
.flashcard.flipped .card-front { transform: rotateY(180deg); }
.flashcard.flipped .card-back { transform: rotateY(360deg); }

.tag, .answer-label {
  display: inline-flex;
  width: fit-content;
  border-radius: 999px;
  padding: 6px 10px;
  font-size: 0.78rem;
  font-weight: 700;
}
.answer-label { background: #eef2ff; color: #4338ca; margin-bottom: 14px; }
.d1 { background: #eeedfe; color: #3c3489; }
.d2 { background: #e1f5ee; color: #085041; }
.d3 { background: #e6f1fb; color: #0c447c; }
.d4 { background: #faece7; color: #712b13; }
.d5 { background: #eaf3de; color: #27500a; }

.controls { justify-content: space-between; }
.empty, .status {
  margin-top: 24px;
  background: #fff;
  border-radius: 18px;
  padding: 24px;
  border: 1px solid #e1e6ef;
}
.error { color: #b42318; }

@media (max-width: 640px) {
  .page { width: min(100% - 20px, 980px); padding-top: 20px; }
  .hero, .card-face { padding: 20px; }
  .flashcard { min-height: 430px; }
}
